APP_NAME="MatchFrame Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database (MySQL for now — switch to Supabase/Postgres later) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=matchframe
DB_USERNAME=root
DB_PASSWORD=

# Driver tables (work out of the box on MySQL)
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@matchframe.app"
MAIL_FROM_NAME="${APP_NAME}"

# ── First admin (used by AdminSeeder / DatabaseSeeder) ──
ADMIN_NAME="MatchFrame Admin"
ADMIN_EMAIL=admin@matchframe.app
ADMIN_PASSWORD=password

# ── API ↔ frontend ──
# Where the Next.js frontend runs (used for Stripe success/cancel redirects)
FRONTEND_URL=http://localhost:3000
# Allowed CORS origins for the API (comma-separated)
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000

# ── Stripe ──
# Stripe keys are managed in the admin panel (Settings → Stripe & pricing),
# NOT here — so they can be changed without a redeploy.
